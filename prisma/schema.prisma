// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ====== TABELA DE USUARIOS ======

enum RoleType {
  ADMIN
  MEMBER
}

model User {
  id            Int        @id @default(autoincrement())
  name          String?
  email         String     @unique
  password      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userRoles     UserRole[]
  tokens        Token[]
  histories     History[]
  createdTasks  Task[]     @relation("TaskCreator")
  assignedTasks Task[]     @relation("TaskAssignees")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      RoleType   @unique
  userRoles UserRole[]
}

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

// ====== TABELA DE TOKEN ======

model Token {
  id        Int       @id @default(autoincrement())
  token     String    @db.VarChar(255)
  type      TypeToken @default(ACCESS)
  revoked   Boolean   @default(false)
  expiresAt DateTime
  userId    Int

  user User @relation(fields: [userId], references: [id])

  @@map("token")
}

enum TypeToken {
  ACCESS
  REFRESH
}

// ====== TABELA DE TAREFAS ======

enum Priority {
  BAIXA
  MEDIA
  ALTA
}

enum Status {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    Priority
  status      Status    @default(PENDENTE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  history     History[]

  createdById Int
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])
  assignees   User[] @relation("TaskAssignees")
}

// ====== TABELA DE HISTÓRICO ======

model History {
  id          String    @id @default(uuid())
  taskId      String
  userId      Int?
  eventType   EventType
  description String?
  createdAt   DateTime  @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
}

enum EventType {
  CREATED
  ASSIGNED
  UPDATED
  COMPLETED
  REOPENED
}