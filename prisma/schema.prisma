// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ====== TABELA DE USUÁRIOS ======

enum RoleType {
  ADMIN
  MEMBER
}

model User {
  id            Int        @id @default(autoincrement())
  name          String?
  email         String     @unique
  password      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userRoles     UserRole[]
  tokens        Token[]
  histories     History[]
  projects      Project[]
  createdTasks  Task[]     @relation("TaskCreator")
  assignedTasks Task[]     @relation("TaskAssignees")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      RoleType   @unique
  userRoles UserRole[]
}

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ====== TABELA DE TOKEN ======

model Token {
  id        Int       @id @default(autoincrement())
  token     String    @db.VarChar(255)
  type      TypeToken @default(ACCESS)
  revoked   Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

enum TypeToken {
  ACCESS
  REFRESH
}

// ====== TABELA DE TAREFAS ======

enum Priority {
  BAIXA
  MEDIA
  ALTA
}

enum Status {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

model Task {
  id          Int    @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  priority    Priority
  status      Status    @default(PENDENTE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projectId   Int?
  history     History[]

  project   Project? @relation(fields: [projectId], references: [id])
  createdById Int
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])
  assignees   User[] @relation("TaskAssignees")
}

// ====== TABELA DE HISTÓRICO ======

model History {
  id          String    @id @default(uuid())
  taskId      Int
  userId      Int?
  eventType   EventType
  description String?
  createdAt   DateTime  @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
}

enum EventType {
  CREATED
  ASSIGNED
  UPDATED
  COMPLETED
  REOPENED
}

// ====== TABELA DE PROJETOS ======

enum KnowledgeArea {
  TECNOLOGIA
  SAUDE
  EDUCACAO
  FINANCAS
  MARKETING
  OUTRO
}

enum ProjectStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model Project {
  id            Int        @id @default(autoincrement())
  title         String
  description   String?
  knowledgeArea KnowledgeArea
  startDate     DateTime?
  endDate       DateTime?
  status        ProjectStatus @default(PLANEJAMENTO)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ownerId       Int

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]
}